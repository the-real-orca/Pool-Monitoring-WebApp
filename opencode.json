{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "read": {
      "src/data/**": "allow"
    },	  
    "external_directory": {
      "/tmp/**": "allow"
    },
    "bash": {
      "*": "ask",
      "ls /tmp/*": "allow",
      "cat /tmp/*": "allow",
      "mkdir /tmp/*": "allow",
      "touch /tmp/*": "allow",
      "cp * /tmp/*": "allow",
      "mv * /tmp/*": "allow"
    }    
  }
}
