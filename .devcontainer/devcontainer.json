// For format details, see https://aka.ms/devcontainer.json. For config options, see the
// README at: https://github.com/devcontainers/templates/tree/main/src/python
{
	"name": "Python 3",
	// Or use a Dockerfile or Docker Compose file. More info: https://containers.dev/guide/dockerfile
	"image": "mcr.microsoft.com/devcontainers/python:3.12-bookworm",
	"features": {
		"ghcr.io/devcontainers/features/node:2": {},
		"ghcr.io/stu-bell/devcontainer-features/open-code:0": {},
//		"ghcr.io/devcontainers/features/docker-in-docker:2": {},
		"ghcr.io/devcontainers/features/docker-in-docker:3": {},
		"ghcr.io/warrenbuckley/codespace-features/sqlite:1": {}
//		"ghcr.io/devcontainers-extra/features/vscode-cli:1": {}
	},

	// Mounts for opencode as Docker volumes
	"mounts": [
		"source=opencode-config,target=/home/vscode/.config/opencode,type=volume",
		"source=opencode-data,target=/home/vscode/.local/share/opencode,type=volume",
		"source=opencode-cache,target=/home/vscode/.cache/opencode,type=volume"
	],

	// Mounts for opencode as directories
	// "mounts": [
	// 	"source=${localWorkspaceFolder}/.opencode/config,target=/home/vscode/.config/opencode,type=bind",
	// 	"source=${localWorkspaceFolder}/.opencode/data,target=/home/vscode/.local/share/opencode,type=bind",
	// 	"source=${localWorkspaceFolder}/.opencode/cache,target=/home/vscode/.cache/opencode,type=bind"
	// ],

	"containerEnv": {
		"OPENCODE_CONFIG_DIR": "/home/vscode/.config/opencode"
	},


	// Use 'forwardPorts' to make a list of ports inside the container available locally.
	// "forwardPorts": [],

	// Use 'postCreateCommand' to run commands after the container is created.
	// "postCreateCommand": "pip3 install --user -r requirements.txt",

	"customizations": {
		"vscode": {
			"extensions": [
				"ankurmathur.opencode-provider-bridge",
				"sst-dev.opencode",
				"ritwickdey.LiveServer",
				"ms-azuretools.vscode-containers",
				"nickcrv.markdown-pdf-vscode",
				"shd101wyy.markdown-preview-enhanced",
				"rpdswtk.vsmqtt",
				"Vue.volar",
				"humao.rest-client",
				"mechatroner.rainbow-csv"
			]
		}
	}

	// Uncomment to connect as root instead. More info: https://aka.ms/dev-containers-non-root.
	// "remoteUser": "root"
}
