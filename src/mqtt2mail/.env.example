# Runtime
TZ=Europe/Vienna
REPORT_INTERVAL_SECONDS=900
SEND_EMPTY_REPORT=false
LOG_LEVEL=INFO

# MQTT
MQTT_HOST=mqtt.example.com
MQTT_PORT=1883
# Either MQTT_USERNAME/PASSWORD or MQTT_USER/PASS can be used.
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_USER=
MQTT_PASS=
MQTT_CLIENT_ID=pool-mqtt-mailer
MQTT_KEEPALIVE=60
MQTT_TLS=false

# Topic selection priority:
# 1) MQTT_TOPICS / MQTT_ALERT_TOPICS / MQTT_AVAILABILITY_TOPICS
# 2) POOL_LIST topics from the Pool-Monitoring app
# 3) MQTT_TOPIC_BASE (+ /alert + /availability)
MQTT_TOPICS=
MQTT_ALERT_TOPICS=
MQTT_AVAILABILITY_TOPICS=
POOL_LIST=[{"name":"Pool 1","topic":"pool1/manual"},{"name":"Pool 2","topic":"pool2/manual"}]
MQTT_TOPIC_BASE=/esp32/sensor/ble-yc01

# Mail report
MAIL_SUBJECT=Pool Übersicht

# Gmail SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_STARTTLS=true
SMTP_USERNAME=your-gmail-address@gmail.com
SMTP_PASSWORD=your-gmail-app-password
MAIL_FROM=your-gmail-address@gmail.com
MAIL_TO=recipient@example.com

# Units and conversions
# Der YC01 liefert Batterie im Beispiel als mV. Fuer Ausgabe in V: mv + V.
BAT_VALUE_UNIT=mv
BAT_DISPLAY_UNIT=V
