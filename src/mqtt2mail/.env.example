# Runtime
TZ=Europe/Vienna
# Entweder REPORT_TIMES (fixe Uhrzeiten) oder REPORT_INTERVAL_MINUTES (Intervall):
REPORT_TIMES=09:00,12:00,16:00
# REPORT_INTERVAL_MINUTES=15  # nur als Fallback wenn REPORT_TIMES leer
SEND_EMPTY_REPORT=false
LOG_LEVEL=INFO

# MQTT
MQTT_HOST=mqtt.example.com
MQTT_PORT=1883
# Either MQTT_USERNAME/PASSWORD or MQTT_USER/PASS can be used.
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_USER=
MQTT_PASS=
MQTT_CLIENT_ID=pool-mqtt-mailer
MQTT_KEEPALIVE=60
MQTT_TLS=false

# Topic selection.
# The pool's ``topic`` field is the BASE topic. mqtt2mail subscribes to
# ``<base>/+`` for data and ``<base>/+/alert`` for alerts, and inspects the
# JSON payload to distinguish measurement / pump / chemistry messages.
POOL_LIST=[{"name":"Pool 1","topic":"home/pool1"},{"name":"Pool 2","topic":"home/pool2"}]

# Mail report
MAIL_SUBJECT=Pool Übersicht

# Gmail SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_STARTTLS=true
SMTP_USERNAME=your-gmail-address@gmail.com
SMTP_PASSWORD=your-gmail-app-password
MAIL_FROM=your-gmail-address@gmail.com
MAIL_TO=recipient@example.com

# Units and conversions
# Der YC01 liefert Batterie im Beispiel als mV. Fuer Ausgabe in V: mv + V.
BAT_VALUE_UNIT=mv
BAT_DISPLAY_UNIT=V
